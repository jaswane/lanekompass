# Lånekompass.no — miljøvariabler
#
# Kopier denne filen til .env.local for lokal utvikling, eller sett verdiene i
# Vercel: Project → Settings → Environment Variables.
#
# Ingen hemmeligheter hører hjemme her. Alle NEXT_PUBLIC_*-variabler bakes inn
# i nettleser-bundelen ved build og er offentlige.

# Base-URL for produksjon. Brukes til canonical, sitemap.xml, robots.txt,
# Open Graph og JSON-LD. Sett til det PRIMÆRE domenet uten etterfølgende
# skråstrek, f.eks. https://www.lanekompass.no
# Verdien leses ved build-tid — sett den i Vercel før deploy.
# Hvis den ikke settes, faller koden tilbake på https://www.lanekompass.no
NEXT_PUBLIC_SITE_URL=https://www.lanekompass.no

# Valgfri Google Analytics 4 måle-ID (format: G-XXXXXXXXXX).
# La stå tom for å skru av analytics. Skriptet lastes kun i produksjon
# OG når denne er satt — aldri i utvikling.
NEXT_PUBLIC_GA_ID=
